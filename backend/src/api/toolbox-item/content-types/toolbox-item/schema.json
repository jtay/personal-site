{
  "kind": "collectionType",
  "collectionName": "toolbox_items",
  "info": {
    "singularName": "toolbox-item",
    "pluralName": "toolbox-items",
    "displayName": "Toolbox Item"
  },
  "options": {
    "draftAndPublish": true
  },
  "attributes": {
    "slug": {
      "type": "string",
      "required": true,
      "unique": true
    },
    "title": {
      "type": "string",
      "required": true
    },
    "subtitle": {
      "type": "string"
    },
    "image": {
      "type": "media",
      "multiple": false,
      "allowedTypes": [
        "images"
      ]
    },
    "htmlPath": {
      "type": "string",
      "required": true
    },
    "color": {
      "type": "string",
      "default": "#000000"
    }
  }
}
